# Version control
.git
.gitignore

# Dependencies (rebuilt inside container)
node_modules
.pnpm-store

# Build output (rebuilt inside container)
dist
.vite

# Claude Code agent workspace — git worktrees + task outputs (3GB+). Never part
# of the build/runtime; including it ballooned the Docker build context past the
# deploy timeout (2026-05-31).
.claude

# Local audit / scan artifacts (reports written by scripts/*.mjs, which are
# themselves excluded below). Not runtime.
.audit

# Logs
*.log
.manus-logs
test_logs

# IDE / OS
.DS_Store
.vscode
.idea

# Environment files (secrets injected via fly secrets set)
.env
.env.local
.env.*.local

# Testing
coverage

# Manus-specific artifacts
.manus
manus.yaml
.manusignore

# Docs / scratchpad
todo.md
*.md
!README.md

# Scripts that don't need to ship (but keep migrate.mjs for Fly release_command)
scripts
!scripts/migrate.mjs
test_gen2.mjs
