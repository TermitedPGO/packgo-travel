# PACK&GO environment variables — example file.
#
# Copy to `.env` and fill in the values for your environment.
# The real `.env` is gitignored. Production secrets live in Fly secrets.
#
# This file documents only the Sentry observability variables added in
# v2 Wave 1 Module 1.1 (2026-05-19). Other env vars (DB, Stripe, Plaid,
# OAuth, S3, etc.) live in fly.toml / fly secrets and the deploy runbook.

# ─── Sentry (v2 Wave 1 Module 1.1, 2026-05-19) ────────────────────────────────
# Free tier 5K events/mo. Create a project at https://sentry.io/signup/ and
# provision a Node + React project to obtain the DSN.

# Server-side DSN. Used by server/_core/sentry.ts → Sentry.init().
# When empty, error reporting is skipped (no crash) — useful for preview deploys.
SENTRY_DSN=

# Client-side DSN. Used by client/src/main.tsx → Sentry.init(). May be the
# same as SENTRY_DSN if you used a single project for both runtimes.
# Vite exposes only VITE_* vars to the browser bundle.
VITE_SENTRY_DSN=

# Auth token for sourcemap upload. Get one from Sentry → User Settings → Auth
# Tokens → New Token. Scope it to `project:write`. Required only when you
# want production builds to upload sourcemaps; dev builds skip when empty.
SENTRY_AUTH_TOKEN=

# Sentry org slug (e.g. "packgo"). Required for the Vite plugin to know
# where to upload sourcemaps. Empty value gates the plugin off.
SENTRY_ORG=

# Sentry project slug (e.g. "packgo-web"). Same gating as SENTRY_ORG.
SENTRY_PROJECT=

# ─── PostHog (v2 Wave 1 Module 1.4, 2026-05-20) ────────────────────────────────
# Conversion-funnel analytics. Free tier 1M events/mo. Create a project at
# https://posthog.com/signup. Region: US Cloud (default — lowest latency from
# Fly IAD).

# Client-side project API key. Used by client/src/_core/analytics.ts →
# initAnalytics() → posthog.init(). When empty, analytics is fully no-op
# (no init, no capture) — dev / preview deploys stay clean and don't burn
# the production quota. Vite exposes only VITE_* vars to the browser bundle.
VITE_POSTHOG_KEY=

# PostHog ingest endpoint. Default `https://us.i.posthog.com` (US Cloud).
# EU users: set to `https://eu.i.posthog.com`. Self-hosted: your instance URL.
VITE_POSTHOG_HOST=https://us.i.posthog.com

# ─── Autonomous-agent tuning (v2 Wave 3 Module 3.12, 2026-05-22) ──────────────
# Per-deploy knobs that gate the skill auto-dispatch path. Both values are
# integers in [0, 100]; out-of-range / missing / non-numeric values fall back
# to the defaults shown. Tune in prod after observing skill draft quality
# (selfRetrospective will surface mis-classifications for review).

# Minimum InquiryAgent confidence required to ATTEMPT skill auto-dispatch.
# Below this, the inquiry skips the registry entirely and escalates to Jeff
# for manual review. Default 80.
AGENT_CONFIDENCE_THRESHOLD=80

# Minimum confidence required to AUTO-SEND a skill's draft (vs leaving it
# in the office inbox for Jeff to send). Always ≥ AGENT_CONFIDENCE_THRESHOLD.
# Refund + complaint NEVER auto-send regardless of confidence (policy rule
# in RefundAgent's alwaysEscalate constitution). Default 90.
AGENT_AUTO_SEND_THRESHOLD=90
