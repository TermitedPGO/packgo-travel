#!/usr/bin/env sh
# Pre-commit gate — added Phase 1 Module 1.5 of Vibe Coding refactor.
# Blocks commits if tsc finds new type errors (after Phase 1 reduced
# baseline from 40 → 0).
#
# To bypass in an emergency: git commit --no-verify -m "..."
# But understand: bypassing here is exactly how 40 errors accumulated.

set -e

echo "[pre-commit] running tsc --noEmit..."
NODE_OPTIONS="--max-old-space-size=6144" pnpm tsc --noEmit
echo "[pre-commit] ✓ tsc clean"
